# ============================================================================================================================ #
#
# For the most up-to-date documentation and variables, see https://github.com/DSmart33/Usenet-Ultimate
#
# All env var overrides follow the priority: env var > config.json > default.
# Active overrides are logged at startup.
#
# ==============================================================================
#                         ESSENTIAL ADDON SETUP
# ==============================================================================

# Base URL override for stream URLs (optional — auto-detected from incoming requests when not set)
# Set this if you need a fixed URL (custom domain, Docker networking, etc.)
# BASE_URL=http://localhost:1337

# HTTP server port
PORT=1337

# ==============================================================================
#                    INDEXER CONFIGURATION (ONE-TIME MIGRATION)
# ==============================================================================
# These values are migrated to config.json on first startup.
# After initial setup, manage indexers through the web UI instead.

# Single indexer
#INDEXER_URL=https://your-indexer.com
#INDEXER_API_KEY=your-api-key-here

# Multiple indexers (comma-separated)
#INDEXER_URL=https://indexer1.com,https://indexer2.com
#INDEXER_API_KEY=key1,key2

# ==============================================================================
#                         CACHE CONFIGURATION
# ==============================================================================
# Also migrated to config.json on first startup; manage via web UI after that.

# Search result cache TTL in seconds (default: 0 = disabled; e.g. 43200 = 12 hours)
#CACHE_TTL=0

# ==============================================================================
#                         INDEX MANAGER
# ==============================================================================
# Runtime overrides — these always take priority over config.json / web UI values.

# Indexer manager type (options: newznab, prowlarr, nzbhydra)
#INDEX_MANAGER=prowlarr

# Prowlarr connection
#PROWLARR_URL=http://prowlarr:9696
#PROWLARR_API_KEY=your-prowlarr-api-key

# NZBHydra connection
#NZBHYDRA_URL=http://nzbhydra:5076
#NZBHYDRA_API_KEY=your-nzbhydra-api-key
#NZBHYDRA_USERNAME=your-nzbhydra-username
#NZBHYDRA_PASSWORD=your-nzbhydra-password

# ==============================================================================
#                         NZBDAV CONNECTION
# ==============================================================================

# NZBDav API and WebDAV configuration
#NZBDAV_URL=http://nzbdav:3000
#NZBDAV_API_KEY=your-nzbdav-api-key
#NZBDAV_WEBDAV_URL=http://nzbdav:3000
#NZBDAV_WEBDAV_USER=admin
#NZBDAV_WEBDAV_PASS=your-webdav-password

# ==============================================================================
#                       BUILT-IN EASYNEWS INDEXER
# ==============================================================================

# Easynews integration (optional)
#EASYNEWS_ENABLED=false
#EASYNEWS_USERNAME=your-easynews-username
#EASYNEWS_PASSWORD=your-easynews-password

# ==============================================================================
#                       STREAMING CONFIGURATION
# ==============================================================================

# Streaming mode (options: nzbdav, stremio)
#STREAMING_MODE=nzbdav

# NZB Fallback — automatically try alternative NZBs when the primary download fails
#NZBDAV_FALLBACK_ENABLED=false

# Fallback order (options: selected, top)
#   selected = start from the NZB you clicked, continue down, wrap around
#   top      = always start from the highest-ranked search result
#NZBDAV_FALLBACK_ORDER=top

# Auto-resolve NZBs from top of list in background (requires fallback order "from top")
#AUTO_RESOLVE_ON_SEARCH=true

# Number of NZBs to Auto-Resolve "From Top of List" (1-4, default: 2 for new installs, 1 for upgrades)
#AUTO_RESOLVE_TARGETS=2

# Max fallback attempts (0 = unlimited — try all search results; 1-20 = limit)
#NZBDAV_MAX_FALLBACKS=0

# How long to wait (seconds) for a stream to become ready before trying the next fallback (1-90)
# Legacy: NZBDAV_JOB_TIMEOUT sets both movie and TV if the specific ones aren't set (clamped to 1-90)
#NZBDAV_MOVIES_TIMEOUT=30
#NZBDAV_TV_TIMEOUT=15
#NZBDAV_SEASON_PACK_TIMEOUT=30
#NZBDAV_JOB_TIMEOUT=120

# Streaming method: proxy (default, dual-stage buffer), pipe, or direct (WebDAV redirect)
# Values are lowercase. Legacy: NZBDAV_PROXY_ENABLED=true/false still accepted (maps to proxy/direct)
#NZBDAV_STREAMING_METHOD=proxy

# Dual-stage proxy buffer size in MB — larger buffers absorb network jitter but use more memory (default: 128, min: 8)
# Legacy: STREAM_BUFFER_MB is still accepted as a fallback
#NZBDAV_STREAM_BUFFER_MB=128

# Pipe mode buffer size in MB (default: 8, min: 1, max: 16)
#NZBDAV_PIPE_BUFFER_MB=8

# Max Stremio self-redirects during fallback chains before giving up (default: 500)
#NZBDAV_MAX_SELF_REDIRECTS=500

# Max upstream reconnect attempts before giving up on a proxied stream (default: 30)
# Legacy: STREAM_MAX_RECONNECTS is still accepted as a fallback
#NZBDAV_STREAM_MAX_RECONNECTS=30

# ==============================================================================
#                       NZB DATABASE
# ==============================================================================

# Filter dead (previously failed) NZBs from search results (default: true)
#FILTER_DEAD_NZBS=true

# Store timed-out NZBs in the dead NZB cache (default: true)
# When false, only permanently failed NZBs are dead
#INCLUDE_TIMEOUTS_AS_DEAD_NZBS=true

# ==============================================================================
#                       SEARCH BEHAVIOR
# ==============================================================================

# Filter out results from wrong remake/reboot version of a show (default: true)
#ENABLE_REMAKE_DETECTION=true

# Allow streaming from combined multi-episode files like S01E01E02 (default: true)
#ALLOW_MULTI_EPISODE_FILES=true

# Remove duplicate results with identical download URLs (default: true)
#URL_DEDUP=true

# ==============================================================================
#                       HTTP PROXY
# ==============================================================================

# Proxy mode (options: disabled, http)
#PROXY_MODE=disabled
#PROXY_URL=http://your-proxy:8080

# ==============================================================================
#                       NZB HEALTH CHECK
# ==============================================================================

# Zyclops verification service endpoint (for NZB health checking)
# Override to point at a self-hosted Zyclops instance
#ZYCLOPS_ENDPOINT=https://zyclops.elfhosted.com

# NNTP-level health checks — define a primary Usenet provider via env vars
# When HEALTH_CHECK_NNTP_HOST is set, it is prepended to any providers in config.json
#HEALTH_CHECK_ENABLED=true
#HEALTH_CHECK_NNTP_HOST=news.your-provider.com
#HEALTH_CHECK_NNTP_PORT=563
#HEALTH_CHECK_NNTP_TLS=true
#HEALTH_CHECK_NNTP_USER=your-usenet-username
#HEALTH_CHECK_NNTP_PASS=your-usenet-password

# Universal override for all indexer search timeouts (seconds, 1-45).
# When set, forces timeouts on and overrides per-indexer and top-level values.
#SEARCH_TIMEOUT=30

# ==============================================================================
#                       ULTIMATE-RESOLVE
# ==============================================================================

# 5-layer parallel NZB resolution pipeline combining WebDAV, NZBDav,
# NZB Fallback, Health Checking, and Priority Grab Queueing
#ULTIMATE_RESOLVE_ENABLED=false

# Number of NZBs to process in parallel (2-10, default: 3)
#ULTIMATE_RESOLVE_CANDIDATE_COUNT=3

# Preference mode: "priority" (highest quality first, default) or "speed" (first healthy wins)
#ULTIMATE_RESOLVE_PREFERENCE_MODE=priority

# Number of article segments to sample per health check (3 or 7)
#ULTIMATE_RESOLVE_SAMPLE_COUNT=3

# Target container-matched backups to pre-cache after the primary stream resolves.
# 0 = don't pull replacements beyond the initial candidate pool; library hits and
# already-grabbed candidates still cache as free backups. 1-10 = target total count. Default 2.
#ULTIMATE_RESOLVE_DESIRED_BACKUPS=2

# Hard cap on the number of NZBs UU will attempt for backup vetting after the
# primary resolves. Dead and duplicate candidates count against this budget;
# library hits do not. 0 = no cap (evaluate all), 1-20 = limit. Default 3.
#ULTIMATE_RESOLVE_BACKUP_PROCESSING_LIMIT=3

# Stream Wait Times (per nzbdav job-completion). Two independent sets — the
# active set is selected by ULTIMATE_RESOLVE_PREFERENCE_MODE at runtime.
# All values clamped 1-90 seconds. Defaults: priority 30/15/30, speed 20/10/20.
#ULTIMATE_RESOLVE_PRIORITY_MOVIES_TIMEOUT=30
#ULTIMATE_RESOLVE_PRIORITY_TV_TIMEOUT=15
#ULTIMATE_RESOLVE_PRIORITY_SEASON_PACK_TIMEOUT=30
#ULTIMATE_RESOLVE_SPEED_MOVIES_TIMEOUT=20
#ULTIMATE_RESOLVE_SPEED_TV_TIMEOUT=10
#ULTIMATE_RESOLVE_SPEED_SEASON_PACK_TIMEOUT=20

# ==============================================================================
#                       ADMIN / MAINTENANCE
# ==============================================================================

# One-time password reset (remove after restart)
# Format with username:  RESET_PASSWORD=username:newpassword
# Single-user shorthand: RESET_PASSWORD=newpassword
#RESET_PASSWORD=
