    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "stremio-addon-sdk": "^1.6.10",
    "uuid": "^13.0.0",
    "webdav": "^5.8.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
